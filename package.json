{
  "name": "saltwaves-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tinacms dev -c \"next dev\"",
    "build": "npm run tina:build && next build",
    "start": "next start",
    "lint": "next lint",
    "dev:next": "next dev",
    "tina:build": "if [ -n \"$NEXT_PUBLIC_TINA_CLIENT_ID\" ] && [ -n \"$TINA_TOKEN\" ]; then tinacms build; else tinacms build --local --skip-cloud-checks; fi",
    "tina:build:local": "tinacms build --local --skip-cloud-checks"
  },
  "dependencies": {
    "@tinacms/cli": "^2.2.3",
    "gray-matter": "^4.0.3",
    "next": "14.2.33",
    "next-mdx-remote": "^6.0.0",
    "react": "^18",
    "react-dom": "^18",
    "tinacms": "^3.7.3"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.33",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
